# Festival Admin — environment template
# Copy to `.env` (gitignored) and fill in real values.

# Backend base URL.
# - 개발(dev) 환경에서 백엔드와 다른 도메인이면 비워두세요. vite.config.ts의 /api 프록시가
#   localhost로 same-origin 처리해줍니다 (쿠키 기반 CSRF가 정상 동작).
# - 프로덕션 빌드는 CI에서 GitHub Actions Variables의 VITE_API_URL을 주입.
VITE_API_URL=

# (선택) 백엔드 없이 모킹된 데이터로 UI를 띄우고 싶을 때만 true
# VITE_USE_MOCK=true

# (선택) dev 프록시 타겟 변경. 기본값: https://api.usw-festival.site
# VITE_DEV_PROXY_TARGET=https://api.usw-festival.site

# (선택) 모킹 응답 지연(ms)
# VITE_MOCK_LATENCY_MS=250

# Supabase Storage (이미지 업로드)
# 1) Supabase 대시보드 → Storage → "images" public bucket 생성
# 2) Policies 탭에서 anon INSERT, public SELECT 허용 (예시 SQL)
#    create policy "anon upload" on storage.objects
#      for insert to anon with check (bucket_id = 'images');
# 3) Project Settings → API에서 Project URL과 anon public key 복사
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
